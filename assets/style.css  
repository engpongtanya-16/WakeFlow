/* ═══════════════════════════════════════════════════════════════
   WakeFlow v2 — CSS Theme
   Aesthetic: Sunrise Gradient — warm orange → cool blue
   Fonts: DM Sans (UI) + DM Mono (code/labels)
   ═══════════════════════════════════════════════════════════════ */

:root {
  --bg-card:     rgba(255, 255, 255, 0.60);
  --bg-input:    rgba(255, 255, 255, 0.85);
  --border:      rgba(255, 255, 255, 0.55);
  --border-dark: rgba(0, 0, 0, 0.11);

  --accent:      #d4560a;
  --accent-2:    #b07a00;
  --blue:        #2563eb;
  --green:       #059669;
  --pink:        #db2777;
  --red:         #dc2626;

  --text:        #1e293b;
  --text-muted:  #4b5563;
  --text-dim:    #9ca3af;

  --font:        'DM Sans',  -apple-system, sans-serif;
  --mono:        'DM Mono',  'Fira Code', monospace;

  --r:           14px;
  --r-sm:        9px;
  --shadow:      0 4px 28px rgba(0, 0, 0, 0.10);
  --shadow-sm:   0 2px 12px rgba(0, 0, 0, 0.07);
}

*, *::before, *::after { box-sizing: border-box; }

html, body {
  min-height: 100vh;
}

body {
  background: linear-gradient(160deg,
    #FC9F66 0%, #FAC357 22%, #FAE39C 42%,
    #B8E0E3 62%, #97C5D8 80%, #84A9CD 100%
  ) fixed !important;
  font-family: var(--font) !important;
  color: var(--text) !important;
  -webkit-font-smoothing: antialiased;
}

/* ── Root wrapper ─────────────────────────────────────────────── */

.wf-root {
  min-height: 100vh;
  padding: 0 28px;
  background: transparent !important;
}

/* ── Header ───────────────────────────────────────────────────── */

.wf-header { border-bottom: 1px solid rgba(0,0,0,0.09); }

.wf-logo {
  font-size: 1.75rem !important;
  font-weight: 700 !important;
  letter-spacing: -.03em;
  color: var(--accent) !important;
  font-family: var(--font) !important;
  line-height: 1.1;
}

.wf-subtitle {
  font-size: 12.5px;
  color: var(--text-muted);
}

/* ── Tabs ─────────────────────────────────────────────────────── */

.wf-tabs .nav-tabs { border-bottom: 1px solid rgba(0,0,0,0.11) !important; }

.wf-tabs .nav-link {
  color: var(--text-muted) !important;
  font-size: 13px; font-weight: 500;
  border: none !important;
  border-bottom: 2px solid transparent !important;
  padding: 10px 18px;
  background: transparent !important;
  transition: color .15s, border-color .15s;
  border-radius: 0 !important;
}

.wf-tabs .nav-link:hover { color: var(--text) !important; }

.wf-tabs .nav-link.active {
  color: var(--accent) !important;
  border-bottom-color: var(--accent) !important;
  background: transparent !important;
}

.tab-content { background: transparent !important; border: none !important; }

/* ── Cards ────────────────────────────────────────────────────── */

.wf-card {
  background: var(--bg-card);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  border: 1px solid var(--border);
  border-radius: var(--r);
  padding: 20px;
  box-shadow: var(--shadow);
}

.wf-card-title {
  font-size: 13.5px !important; font-weight: 600 !important;
  color: var(--accent) !important; font-family: var(--font) !important;
  margin-bottom: 12px; letter-spacing: -.01em;
}

/* ── Inputs ───────────────────────────────────────────────────── */

.wf-input, .wf-input input, .wf-input .form-control,
.form-control {
  background: var(--bg-input) !important;
  color: var(--text) !important;
  border: 1px solid var(--border-dark) !important;
  border-radius: var(--r-sm) !important;
  font-family: var(--font) !important;
  font-size: 13.5px !important;
  box-shadow: var(--shadow-sm) !important;
}

.wf-input:focus, .wf-input input:focus, .wf-input .form-control:focus,
.form-control:focus {
  border-color: var(--accent) !important;
  box-shadow: 0 0 0 3px rgba(212,86,10,.14) !important;
}

/* ── Date picker ──────────────────────────────────────────────── */

.wf-datepicker .DateInput_input {
  background: var(--bg-input) !important;
  color: var(--text) !important;
  border: 1px solid var(--border-dark) !important;
  border-radius: var(--r-sm) !important;
  font-family: var(--font) !important;
  font-size: 14px !important;
  font-weight: 500 !important;
}

.wf-datepicker .DateInput_input::placeholder { color: var(--text-muted) !important; }

/* Calendar panel */
.DayPicker, .DayPicker__withBorder {
  background: rgba(255,255,255,0.95) !important;
  backdrop-filter: blur(14px) !important;
  border: 1px solid var(--border-dark) !important;
  border-radius: var(--r) !important;
  box-shadow: var(--shadow) !important;
}

.DayPicker_transitionContainer, .CalendarMonth, .CalendarMonthGrid {
  background: transparent !important;
}

.CalendarDay__default {
  color: var(--text) !important;
  background: transparent !important;
  border-color: transparent !important;
}

.CalendarDay__default:hover {
  background: rgba(212,86,10,0.10) !important;
  color: var(--accent) !important;
}

.CalendarDay__selected, .CalendarDay__selected:hover {
  background: var(--accent) !important;
  border-color: var(--accent) !important;
  color: #fff !important;
}

.CalendarMonth_caption, .DayPickerNavigation_button__default svg { color: var(--text) !important; }

.DayPickerNavigation_button {
  background: rgba(255,255,255,0.85) !important;
  border: 1px solid var(--border-dark) !important;
  border-radius: var(--r-sm) !important;
}

/* Month/year dropdowns inside datepicker */
.DateInput_fang { display: none; }

/* ── Chat window ──────────────────────────────────────────────── */

.wf-chat-window {
  height: 400px; overflow-y: auto; padding: 16px;
  background: rgba(255,255,255,0.42);
  backdrop-filter: blur(10px);
  border: 1px solid var(--border);
  border-radius: var(--r);
  scroll-behavior: smooth;
  box-shadow: var(--shadow-sm);
}

.wf-chat-window::-webkit-scrollbar { width: 3px; }
.wf-chat-window::-webkit-scrollbar-thumb { background: rgba(0,0,0,0.15); border-radius: 99px; }

.wf-bubble {
  padding: 10px 14px; border-radius: var(--r);
  font-size: 13.5px; line-height: 1.65; max-width: 90%; word-break: break-word;
}

.wf-bubble-ai {
  background: rgba(255,255,255,0.82);
  border: 1px solid rgba(0,0,0,0.07);
  margin-right: auto;
  border-radius: 4px var(--r) var(--r) var(--r);
  color: var(--text);
  box-shadow: var(--shadow-sm);
}

.wf-bubble-user {
  margin-left: auto;
  background: rgba(37,99,235,0.13);
  border: 1px solid rgba(37,99,235,0.22);
  border-radius: var(--r) 4px var(--r) var(--r);
  color: var(--text);
}

/* ── Chat input bar ───────────────────────────────────────────── */

.wf-chat-bar .form-control {
  background: var(--bg-input) !important; color: var(--text) !important;
  border: 1px solid var(--border-dark) !important;
  border-right: none !important;
  font-family: var(--font) !important; font-size: 13.5px !important;
}

.wf-send-btn {
  background: var(--accent) !important; border-color: var(--accent) !important;
  font-weight: 600 !important; font-family: var(--font) !important;
  font-size: 13px !important; color: #fff !important;
  border-radius: 0 var(--r-sm) var(--r-sm) 0 !important;
}

.wf-send-btn:hover { background: #b84508 !important; border-color: #b84508 !important; }

/* ── News cards ───────────────────────────────────────────────── */

.wf-news-card {
  background: var(--bg-card) !important;
  backdrop-filter: blur(10px) !important;
  border: 1px solid var(--border) !important;
  border-radius: var(--r-sm) !important;
  box-shadow: var(--shadow-sm) !important;
  transition: box-shadow .15s, transform .15s;
}

.wf-news-card:hover {
  box-shadow: 0 6px 28px rgba(0,0,0,0.12) !important;
  transform: translateY(-1px);
}

.wf-news-title  { color: var(--text) !important; font-size: 13.5px !important; font-weight: 500 !important; }
.wf-news-desc   { color: var(--text-muted) !important; font-size: 12px !important; }
.wf-news-time   { color: var(--text-dim); font-size: 11px; font-family: var(--mono); }
.wf-news-link   { color: var(--blue); font-size: 12px; font-weight: 500; text-decoration: none; }
.wf-news-link:hover { color: #1d4ed8; }

/* ── Weather stats ────────────────────────────────────────────── */

.wf-stat-label { color: var(--text-muted); font-size: 11.5px; margin-bottom: 2px; }
.wf-stat-val   { color: var(--text) !important; font-weight: 600 !important; font-size: 18px !important; }

/* ── Checklist ────────────────────────────────────────────────── */

.wf-checklist label { color: var(--text-muted) !important; font-size: 13px !important; cursor: pointer; margin-right: 14px; }

/* ── Misc ─────────────────────────────────────────────────────── */

.wf-divider  { border-color: rgba(0,0,0,0.08) !important; margin: 14px 0; }
.wf-hint     { color: var(--text-dim); font-size: 12px; }
.wf-label    { color: var(--text-muted) !important; font-size: 13px !important; font-weight: 500 !important; margin-bottom: 4px !important; }
.wf-tool-row { display: flex; align-items: center; margin-bottom: 10px; }
.wf-badge    { font-size: 12px !important; padding: 6px 12px !important; border-radius: 99px !important; }

/* ── Buttons ──────────────────────────────────────────────────── */

.btn-warning {
  background: var(--accent) !important; border-color: var(--accent) !important;
  color: #fff !important; font-weight: 600 !important;
}

.btn-warning:hover { background: #b84508 !important; border-color: #b84508 !important; }

/* ── Alerts ───────────────────────────────────────────────────── */

.alert { font-family: var(--font) !important; font-size: 13px !important; border-radius: var(--r-sm) !important; }

/* ── Plotly modebar ───────────────────────────────────────────── */

.js-plotly-plot .plotly .modebar { display: none !important; }

/* ── Scrollbar ────────────────────────────────────────────────── */

* { scrollbar-width: thin; scrollbar-color: rgba(0,0,0,0.14) transparent; }